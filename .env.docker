# ── Configuration Docker ─────────────────────────────────────────
# Change "sqlite" → "mysql" pour utiliser MySQL + phpMyAdmin
# Puis lance : docker compose --profile mysql up -d --build
DB_PROVIDER=mysql

PORT=8787

# ── MySQL (utilisé seulement si DB_PROVIDER=mysql) ──────────────
DB_HOST=mysql
DB_PORT=3306
DB_USER=orienteering
DB_PASSWORD=orienteering
DB_NAME=orienteering
