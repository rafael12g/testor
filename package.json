{
  "name": "testor",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n API,VITE -c green,cyan \"npm run api\" \"npm run dev:front\"",
    "dev:front": "vite",
    "api": "node server/index.js",
    "api:mysql": "cross-env DB_PROVIDER=mysql node server/index.js",
    "dev:mysql": "concurrently -n API,VITE -c green,cyan \"npm run api:mysql\" \"npm run dev:front\"",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down --remove-orphans",
    "docker:mysql": "docker compose --profile mysql up -d --build",
    "docker:mysql:down": "docker compose --profile mysql down --remove-orphans",
    "docker:logs": "docker compose logs -f app",
    "docker:reset": "docker compose down -v --remove-orphans",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.563.0",
    "mysql2": "^3.17.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-leaflet": "^5.0.0",
    "sql.js": "^1.14.0",
    "vue": "^3.5.28",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "vite": "^7.3.1"
  }
}
